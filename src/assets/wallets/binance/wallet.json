{
  "id": "binance",
  "name": "Binance Wallet",
  "namespace": "binancew3w.isExtension",
  "rdns": "com.binance.wallet",
  "flag": "isBinance",
  "iconBackground": "#000000",
  "downloadUrls": {
    "android": "https://play.google.com/store/apps/details?id=com.binance.dev",
    "ios": "https://apps.apple.com/us/app/id1436799971",
    "mobile": "https://www.binance.com/en/download",
    "qrCode": "https://www.binance.com/en/web3wallet",
    "chrome": "https://chromewebstore.google.com/detail/cadiboklkpojfamcoggejbbdjcoiljjk"
  },
  "icon": "/assets/wallets/binance/wallet.svg",
  "mobile": {
    "uriTemplates": {
      "android": "{uri}",
      "ios": "bnc://app.binance.com/cedefi/wc?uri={uri}",
      "default": "bnc://app.binance.com/cedefi/wc?uri={uri}"
    },
    "deeplinkTemplate": {
      "deeplink": "https://app.binance.com/en/download?_dp=${deeplink}"
    }
  }
}
